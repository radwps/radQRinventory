# General
APP_TITLE=RAD Box QR Inventory
PUBLIC_BASE_URL=
STORE_MODE=mock
ALLOW_NEGATIVE_STOCK=false
ENABLE_KITS=false

# Mock mode
MOCK_DB_PATH=./demo_data/radbox_inventory.db
SEED_FILE=./demo_data/seed.json

# Airtable mode for RAD Operations Tracker (LIVE) -> Inventory
# The app will also fall back to BOM Line Items automatically if needed.
AIRTABLE_PAT=pat_xxx
AIRTABLE_BASE_ID=app_xxx
AIRTABLE_PARTS_TABLE=Inventory
AIRTABLE_TRANSACTIONS_TABLE=Inventory Transactions
AIRTABLE_KITS_TABLE=Kits
AIRTABLE_KIT_ITEMS_TABLE=Kit Items
AIRTABLE_SYNC_MODE=direct_count
AIRTABLE_FILTER_TO_CATALOG=true
AIRTABLE_LOG_TRANSACTIONS=false

FIELD_PART_SKU=
FIELD_PART_NAME=Line Item Name
FIELD_PART_CONTAINER=
FIELD_PART_STARTING_QTY=
FIELD_PART_ON_HAND=Quantity In Stock
FIELD_PART_REORDER_LEVEL=

FIELD_TXN_PART=Part
FIELD_TXN_SKU=SKU
FIELD_TXN_ACTION=Action
FIELD_TXN_QUANTITY=Quantity
FIELD_TXN_DELTA=Delta
FIELD_TXN_BATCH_ID=Batch ID
FIELD_TXN_OPERATOR=Operator
FIELD_TXN_NOTE=Note
FIELD_TXN_SOURCE=Source
FIELD_TXN_SCANNED_AT=Scanned At

FIELD_KIT_CODE=Kit Code
FIELD_KIT_NAME=Kit Name
FIELD_KIT_ITEM_KIT=Kit
FIELD_KIT_ITEM_PART=Part
FIELD_KIT_ITEM_QTY=Qty Per Kit
